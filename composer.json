{
    "name": "happytodev/blogr-artist",
    "description": "Artist portfolio plugin for Blogr — artworks, portfolio pages, and commission management.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fr\u00e9d\u00e9ric Blanc",
            "email": "happytodev@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "happytodev/blogr": "^1.18",
        "filament/filament": "^4.8",
        "spatie/laravel-package-tools": "^1.15",
        "spatie/eloquent-sortable": "^4.2"
    },
    "require-dev": {
        "orchestra/testbench": "^10.11",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Happytodev\\BlogrArtist\\": "src/",
            "Happytodev\\BlogrArtist\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Happytodev\\BlogrArtist\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Happytodev\\BlogrArtist\\BlogrArtistServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
